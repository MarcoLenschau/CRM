# Example environment variables for the CRM project
# Copy this file to `.env` and replace the placeholder values with real ones.

# Frontend configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Database configuration
# Example: local MongoDB (replace with your connection string)
MONGODB_URI=mongodb://localhost:27017/db_example

# JWT configuration
# Use a long, random secret in production. DO NOT commit your real secret.
JWT_SECRET=your_jwt_secret_here_change_me

# Email (SMTP) configuration
# Example values; replace with your SMTP provider credentials or use Ethereal for tests.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=example_password_replace_me
SUPPORT_EMAIL=no-reply@example.com
